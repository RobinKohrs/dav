# TEST YOUR UN OCHA FUNCTIONS – FULL DETAILED DATA FOR ALL 4 DATASETS
# ============================================================================
# Copy and paste the ENTIRE script into a fresh R console.
# It will use your existing functions (as defined in your current environment)
# and show exactly what works and what doesn't.
# ── Ensure required packages are installed ────────────────────────────────
required_pkgs <- c("httr", "jsonlite", "dplyr", "cli", "tibble", "clipr")
for (pkg in required_pkgs) {
if (!requireNamespace(pkg, quietly = TRUE)) {
install.packages(pkg)
}
}
library(httr)
library(jsonlite)
library(dplyr)
library(cli)
library(tibble)
library(clipr)
# ── Helper: capture printed output (to keep debug messages visible) ──────
capture_with_debug <- function(expr) {
sink(tempfile())  # temporary diversion to avoid cluttering console
result <- tryCatch(expr, error = function(e) e)
sink()
result
}
# ── Test each dataset ─────────────────────────────────────────────────────
cat("\n=== TESTING un_ocha_fatalities_all() ===\n")
datasets <- c("pal_fatalities", "isr_fatalities", "pal_injuries", "isr_injuries")
results <- list()
for (d in datasets) {
cat("\n--------------------------------------------------\n")
cat("Fetching: ", d, "\n")
# Run the function with debug_dsr = TRUE to see DSR structure (first page only)
res <- capture_with_debug(
un_ocha_fatalities_all(type = d, debug_dsr = TRUE)
)
if (inherits(res, "error")) {
cat("❌ ERROR:", conditionMessage(res), "\n")
results[[d]] <- NULL
} else {
results[[d]] <- res
if (is.null(res) || nrow(res) == 0) {
cat("⚠️  Retrieved 0 rows.\n")
} else {
cat("✅ Retrieved", nrow(res), "rows,", ncol(res), "columns.\n")
cat("Column names: ", paste(names(res), collapse = ", "), "\n")
cat("First 3 rows:\n")
print(head(res, 3))
}
}
}
# ── Summary of all results ────────────────────────────────────────────────
cat("\n==================================================\n")
cat("SUMMARY\n")
for (d in datasets) {
df <- results[[d]]
if (is.null(df)) {
cat(d, ": FAILED (error)\n")
} else {
cat(d, ": ", nrow(df), " rows, ", ncol(df), " cols\n")
}
}
# ── Copy results to clipboard ─────────────────────────────────────────────
# Create a compact summary list (first 5 rows of each dataset)
clipboard_obj <- lapply(datasets, function(d) {
df <- results[[d]]
if (is.null(df)) return("ERROR")
if (nrow(df) == 0) return("0 rows returned")
head(df, 5)
})
names(clipboard_obj) <- datasets
# Write to clipboard (as a formatted string)
write_clip(capture.output(print(clipboard_obj)))
cat("\n✅ A summary (first 5 rows of each dataset) has been copied to your clipboard.\n")
cat("   Paste it anywhere to see the structure.\n\n")
devtools::load_all()
