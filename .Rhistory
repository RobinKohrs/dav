# ============================================================================
# Fetch ALL detailed data from UN OCHA (all columns, all datasets)
# ============================================================================
# Copy and paste the entire script into a fresh R console.
# It will take a few minutes to download all data.
# A summary will be copied to your clipboard afterwards.
# ── Ensure required packages are installed ────────────────────────────────
required_pkgs <- c("httr", "jsonlite", "dplyr", "cli", "tibble", "clipr")
for (pkg in required_pkgs) {
if (!requireNamespace(pkg, quietly = TRUE)) {
install.packages(pkg)
}
}
library(httr)
library(jsonlite)
library(dplyr)
library(cli)
library(tibble)
library(clipr)
# ── Helper: fetch schema to get all column names ─────────────────────────
get_all_columns <- function(type, table) {
# type: "pal_fatalities", "isr_fatalities", "pal_injuries", "isr_injuries"
# table: view name (e.g., "vw_BS_Pal_Fatalities")
cols <- tryCatch(
un_ocha_get_schema(type, table = table),
error = function(e) NULL
)
if (is.null(cols)) {
warning("Could not fetch schema for ", type, ". Using fallback columns.")
return(NULL)
}
# Exclude technical/internal columns (starting with "order", "Index", etc.)
exclude <- c("order", "order1", "Index", "Death_Id", "Gov_Id", "Context_Id",
"Affiliation_Id", "Doer_Nationality_Id", "Nationality_id",
"Communiyt_PCODE", "Country_Id", "Submitted", "Approved", "Keywords",
"Desc_", "Name", "East Jerusalem", "New_Sub_Type", "Victim belonging amnd")
cols <- cols[!cols %in% exclude]
# Keep only columns that are likely useful (strings, dates, or the measure)
cols
}
# ── Extend un_ocha_fatalities_all with all columns (dynamic) ─────────────
# We'll create a wrapper that overrides the group_cols inside the function.
# To avoid modifying the original function, we'll copy and modify it locally.
un_ocha_fatalities_all_allcols <- function(type, date_range = NULL, debug_dsr = FALSE) {
# Define the base metadata – same as original but with group_cols replaced later
meta_base <- list(
pal_fatalities = list(
label       = "Palestinian Fatalities",
key         = "60eca1ef-5852-4807-9bc3-4fdb8915c71c",
entity      = "vw_BS_Pal_Fatalities",
src         = "v",
count_col   = "Fat",
count_fn    = 0L,
date_col    = "Date",
req_filters = list(),
dataset_id  = "6837d825-7b35-486b-83b4-d8ffc90325f0",
report_id   = "ab42e258-22eb-4acc-8b6f-6cb117f95baa",
model_id    = 1272287L,
default_date_range = NULL
),
pal_injuries = list(
label       = "Palestinian Injuries",
key         = "d65f26ab-1d4c-4c33-a5e0-8a4afe12ce1c",
entity      = "vw_BS_Pal_Injuries",
src         = "v1",
count_col   = "Inj",
count_fn    = 0L,
date_col    = "Date:",
req_filters = list(ocha_make_in_filter("v1", "Poc_Period", c("yes", "Yes"))),
dataset_id  = "b9ab430a-525d-4bc8-8397-e0edd45cd453",
report_id   = "46625751-da8a-42a6-a3e8-d4a3f1a4d570",
model_id    = 1272286L,
default_date_range = c("2008-01-01", format(Sys.Date(), "%Y-%m-%d"))
),
isr_fatalities = list(
label       = "Israeli Fatalities",
key         = "e167c357-daaa-42bd-aa73-e539ee14a2d4",
entity      = "vw_BS_Isr_Fatalities",
src         = "v1",
count_col   = "Fatalities",
count_fn    = 5L,
date_col    = "Date",
req_filters = list(),
dataset_id  = "c1523f44-2968-4e6a-979a-5bb84a1f4cde",
report_id   = "c8856647-e870-4856-befa-0f9087f8e236",
model_id    = 1300830L,
default_date_range = NULL
),
isr_injuries = list(
label       = "Israeli Injuries",
key         = "ebeb5c54-2c96-4a9c-b913-6a7a8ccf8c00",
entity      = "vw_BS_Isr_Injuries",
src         = "v",
count_col   = "Injuries ",
count_fn    = 5L,
date_col    = "Date",
req_filters = list(),
dataset_id  = "5bd7183c-420b-4727-b350-298104f4d4e7",
report_id   = "71f0e246-4767-41d7-882a-9c228a537cdc",
model_id    = 1272285L,
default_date_range = NULL
)
)
cfg <- meta_base[[type]]
if (is.null(cfg)) stop("Unknown type: ", type)
# Get all column names for this entity
all_cols <- get_all_columns(type, cfg$entity)
if (is.null(all_cols)) {
# Fallback to original column set
if (type == "pal_fatalities") all_cols <- c("Date", "Area", "Govornorate (groups)", "Doer Aff. (groups)", "doer nat")
else if (type == "pal_injuries") all_cols <- c("Date:", "Area", "Govornorate (groups)", "Doer Aff. (groups)", "doer nat")
else if (type == "isr_fatalities") all_cols <- c("Date", "Region", "victim_affiliation (groups) 2")
else if (type == "isr_injuries") all_cols <- c("Date", "Community")
}
# Ensure the date column is first (required for ordering)
if (cfg$date_col %in% all_cols) {
all_cols <- c(cfg$date_col, setdiff(all_cols, cfg$date_col))
}
# Build Select list
select_list <- lapply(all_cols, function(col) {
list(
Column = list(
Expression = list(SourceRef = list(Source = cfg$src)),
Property   = col
),
Name = paste0(cfg$entity, ".", col)
)
})
# Append the aggregation (count measure)
count_prefix <- if (cfg$count_fn == 0L) "Sum" else "CountNonNull"
count_name   <- paste0(count_prefix, "(", cfg$entity, ".", cfg$count_col, ")")
select_list <- c(select_list, list(list(
Aggregation = list(
Expression = list(
Column = list(
Expression = list(SourceRef = list(Source = cfg$src)),
Property   = cfg$count_col
)
),
Function = cfg$count_fn
),
Name = count_name
)))
projections <- as.list(seq_along(select_list) - 1L)
order_by <- list(list(
Direction = 1L,
Expression = list(
Column = list(
Expression = list(SourceRef = list(Source = cfg$src)),
Property   = all_cols[1]
)
)
))
where_filters <- cfg$req_filters
# Date range
effective_date_range <- if (!is.null(date_range)) date_range else cfg$default_date_range
if (!is.null(effective_date_range)) {
where_filters <- c(where_filters,
list(ocha_make_date_filter(cfg$src, cfg$date_col,
effective_date_range[1], effective_date_range[2])))
}
query_inner <- list(
Version = 2L,
From    = list(list(Name = cfg$src, Entity = cfg$entity, Type = 0L)),
Select  = select_list,
OrderBy = order_by
)
if (length(where_filters) > 0L) query_inner$Where <- where_filters
build_payload <- function(restart_token = NULL) {
win <- list(Count = 50000L)  # increase page size for speed
if (!is.null(restart_token)) win$RestartTokens <- list(restart_token)
list(
version = "1.0.0",
queries = list(list(
Query = list(
Commands = list(list(
SemanticQueryDataShapeCommand = list(
Query   = query_inner,
Binding = list(
Primary       = list(Groupings = list(list(Projections = projections))),
DataReduction = list(DataVolume = 3L, Primary = list(Window = win)),
Version       = 1L
)
)
))
),
QueryId            = "",
ApplicationContext = list(
DatasetId = cfg$dataset_id,
Sources   = list(list(ReportId = cfg$report_id))
)
)),
cancelQueries = list(),
modelId       = cfg$model_id
)
}
effective_key <- cfg$key
for (attempt in seq_len(2L)) {
cli::cli_alert_info("Fetching all {cfg$label} data (all columns)...")
df_out <- tryCatch(
ocha_fetch_powerbi(effective_key, build_payload(), debug_dsr = debug_dsr),
ocha_401_error = function(e) {
if (attempt == 1L) {
cli::cli_alert_warning("Resource key stale, refreshing...")
fresh <- tryCatch(un_ocha_get_resource_keys(), error = function(ke) NULL)
if (!is.null(fresh) && !is.na(fresh[[type]])) {
effective_key <<- fresh[[type]]
return(NULL)
}
}
structure(list(msg = conditionMessage(e)), class = "ocha_fetch_err")
},
error = function(e) structure(list(msg = conditionMessage(e)), class = "ocha_fetch_err")
)
if (inherits(df_out, "ocha_fetch_err")) {
cli::cli_alert_warning("Failed: {df_out$msg}")
return(NULL)
}
if (!is.null(df_out)) {
# Convert date column
if (nrow(df_out) > 0L && cfg$date_col %in% names(df_out)) {
df_out[[cfg$date_col]] <- as.Date(
as.POSIXct(as.numeric(df_out[[cfg$date_col]]) / 1000, origin = "1970-01-01", tz = "UTC")
)
if (cfg$date_col != "Date") names(df_out)[names(df_out) == cfg$date_col] <- "Date"
}
cli::cli_alert_success("Retrieved {nrow(df_out)} rows, {ncol(df_out)} columns.")
return(df_out)
}
}
NULL
}
# ── Fetch all datasets ─────────────────────────────────────────────────────
cat("\n========================================\n")
cat("Fetching ALL detailed data (this may take several minutes)\n")
cat("========================================\n\n")
all_data <- list(
pal_fatalities = un_ocha_fatalities_all_allcols("pal_fatalities"),
isr_fatalities = un_ocha_fatalities_all_allcols("isr_fatalities"),
pal_injuries   = un_ocha_fatalities_all_allcols("pal_injuries"),
isr_injuries   = un_ocha_fatalities_all_allcols("isr_injuries")
)
# ── Create a compact summary for clipboard ────────────────────────────────
summary_list <- lapply(names(all_data), function(nm) {
df <- all_data[[nm]]
if (is.null(df)) return(paste(nm, ": FAILED"))
if (nrow(df) == 0) return(paste(nm, ": 0 rows"))
# First 5 rows + column names
list(
dataset = nm,
rows = nrow(df),
cols = ncol(df),
column_names = names(df),
head = head(df, 5)
)
})
names(summary_list) <- names(all_data)
# Write a human‑readable summary to clipboard
clipboard_text <- capture.output({
cat("=== UN OCHA DATA SUMMARY (ALL COLUMNS) ===\n\n")
for (nm in names(all_data)) {
cat("===", toupper(nm), "===\n")
df <- all_data[[nm]]
if (is.null(df)) {
cat("ERROR: Failed to fetch\n\n")
} else if (nrow(df) == 0) {
cat("No rows returned\n\n")
} else {
cat("Rows:", nrow(df), " | Columns:", ncol(df), "\n")
cat("Column names:\n")
print(names(df))
cat("\nFirst 5 rows:\n")
print(head(df, 5))
cat("\n\n")
}
}
})
write_clip(clipboard_text)
cat("\n✅ Summary copied to clipboard. Paste it here to verify all columns.\n")
un_ocha_get_schema("isr_fatalities", table = "vw_BS_Pal_Fatalities")
un_ocha_get_schema("isr_fatalities", table = "vw_BS_Pal_Fatalities") %>% clipr::write_clip()
